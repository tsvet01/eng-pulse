// Copy this file to Secrets.xcconfig and add your API key.
// Secrets.xcconfig is gitignored and will not be committed.
//
// To get a key, enable the Cloud Text-to-Speech API in your GCP console
// and create an API key (your existing Gemini key may work if TTS API is enabled).
GOOGLE_CLOUD_TTS_API_KEY = YOUR_API_KEY
